# ===========================================================================
# Configuration INTER COLIS SERVICES — copiez ce fichier en « .env »
# et renseignez vos valeurs. NE COMMITEZ JAMAIS le fichier .env réel.
# ===========================================================================

# Port d'écoute interne de l'application (nginx fera le lien avec le port 80/443)
PORT=3000

# Secret de signature des sessions (OBLIGATOIRE en production).
# Générez-en un avec :  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=remplacez-par-une-longue-valeur-aleatoire

# Emplacement de la base de données (fichier JSON). Laissez tel quel ou
# pointez vers un dossier sauvegardé (ex. /home/ics/data).
DATA_DIR=/home/ics/inter-colis/data

# --- Envoi d'emails (facultatif) -------------------------------------------
# Renseignez ces variables pour activer l'envoi des identifiants et des
# confirmations de congés. Sans elles, l'app fonctionne sans email.
# Exemple avec un email OVH (MX Plan) :
#SMTP_HOST=ssl0.ovh.net
#SMTP_PORT=465
#SMTP_SECURE=true
#SMTP_USER=contact@inter-colis-services.com
#SMTP_PASS=motdepasse-de-la-boite-email
#MAIL_FROM=Inter Colis Services <contact@inter-colis-services.com>
#APP_URL=https://inter-colis-services.com

# --- Persistance Redis (facultatif, alternative au fichier JSON) -----------
# Inutile sur un VPS OVH : le fichier JSON est conservé sur le disque.
#KV_REST_API_URL=
#KV_REST_API_TOKEN=
